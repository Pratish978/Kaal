# FastAPI Backend Configuration
# The URL where your FastAPI backend is running
FASTAPI_BASE_URL=http://localhost:8000

# API Authentication Key
# This key is sent as X-API-Key header to FastAPI backend
API_KEY=andai

# Next.js Public API URL (optional, for frontend only)
# Leave empty if using relative paths (/api/*)
NEXT_PUBLIC_API_URL=

# Next.js Public API Key (optional)
# If set, will be used by API client
NEXT_PUBLIC_API_KEY=andai

# Supabase Authentication Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Note: The anon key is public and safe to expose in the browser
# It should have Row Level Security (RLS) policies configured in Supabase
